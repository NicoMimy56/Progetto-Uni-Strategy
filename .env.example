# Copia questo file in `.env` e compila SMTP_PASS. All'avvio `server.js` carica automaticamente `.env` (pacchetto `dotenv`).

PORT=3000

# URL pubblico dell’app (senza slash finale): usato nei link «conferma email» in registrazione. In locale: http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Richieste di implementazione (POST /api/feature-requests): destinatario (default nel codice: universitystrategy288@gmail.com)
FEEDBACK_TO_EMAIL=universitystrategy288@gmail.com

# SMTP (obbligatorio per l'invio effettivo; senza SMTP_HOST o SMTP_PASS la richiesta resta solo nel DB)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# true solo per porta 465 (TLS implicito)
SMTP_SECURE=false
SMTP_USER=universitystrategy288@gmail.com
# Password app Google (16 caratteri, dopo 2FA). Spazi e virgolette ok; non la password normale dell’account.
SMTP_PASS=
# Mittente envelope (di solito uguale a SMTP_USER con Gmail)
SMTP_FROM=universitystrategy288@gmail.com
