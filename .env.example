# Copia in `.env` (o esporta in shell) e compila i valori. Il server non carica `.env` da solo:
# usa `export $(grep -v '^#' .env | xargs)` oppure un process manager che inietta le variabili.

PORT=3000

# Richieste di implementazione (POST /api/feature-requests): email in arrivo
FEEDBACK_TO_EMAIL=progetto@example.com

# SMTP (obbligatori per l'invio; senza questi la richiesta resta solo nel DB)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# true solo per porta 465 (TLS implicito)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Mittente envelope (default: SMTP_USER)
SMTP_FROM=
