# Copia questo file in `.env` e compila SMTP_PASS. All'avvio `server.js` carica automaticamente `.env` (pacchetto `dotenv`).

PORT=3000
TZ=Europe/Rome

# URL pubblico dell’app (senza slash finale): usato nei link «conferma email» in registrazione.
# In locale: http://localhost:3000
# In LAN: http://192.168.x.x:3000
# Con Tailscale sul Raspberry: http://100.x.y.z:3000  ← sostituisci con il tuo IP Tailscale
APP_BASE_URL=http://192.168.1.150:3000

# Docker/CasaOS: cartella dati nel container (docker-compose imposta DATABASE_DIR=/data e monta ./Database).
# In sviluppo locale lascia commentato: il DB resta in unistrategy.db nella radice progetto.
# DATABASE_DIR=/data

# Registrazione chiusa al pubblico: uno o più codici separati da virgola (obbligatori per creare un account).
REGISTRATION_INVITE_CODES=CICCIOBROCCO56
REGISTRATION_INVITE_MAX_USES=5

# Promemoria calendario (opzionale)
# CALENDAR_REMINDER_HOUR=8
# CALENDAR_REMINDER_DISABLED=false

# Richieste di implementazione (POST /api/feature-requests): destinatario (default nel codice: universitystrategy288@gmail.com)
FEEDBACK_TO_EMAIL=universitystrategy288@gmail.com

# SMTP (obbligatorio per l'invio effettivo; senza SMTP_HOST o SMTP_PASS la richiesta resta solo nel DB)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# true solo per porta 465 (TLS implicito)
SMTP_SECURE=false
SMTP_USER=universitystrategy288@gmail.com
# Password app Google (16 caratteri, dopo 2FA). Spazi e virgolette ok; non la password normale dell’account.
SMTP_PASS=^xPu3QlprC08
# Mittente envelope (di solito uguale a SMTP_USER con Gmail)
SMTP_FROM=universitystrategy288@gmail.com
