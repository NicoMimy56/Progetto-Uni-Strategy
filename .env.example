# Copy this file to `.env` and fill in your values.
# Never commit `.env` to Git — it contains secrets.

PORT=3000
TZ=Europe/Rome

# Public URL of the app (no trailing slash). Used in email verification links.
# Local:   http://localhost:3000
# LAN:     http://192.168.1.50:3000
# Tailscale: http://100.x.y.z:3000
APP_BASE_URL=http://localhost:3000

# Docker/CasaOS: data directory inside the container (docker-compose sets DATABASE_DIR=/data).
# Leave commented for local development — the DB stays at ./unistrategy.db in the project root.
# DATABASE_DIR=/data

# Invite-only registration: comma-separated secret codes (required to open sign-ups).
REGISTRATION_INVITE_CODES=change-me-to-a-long-random-secret
REGISTRATION_INVITE_MAX_USES=5

# Calendar email reminders (optional)
# CALENDAR_REMINDER_HOUR=8
# CALENDAR_REMINDER_DISABLED=false

# Feature requests tab: recipient email
FEEDBACK_TO_EMAIL=you@example.com

# SMTP (required for email verification and calendar reminders)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
# Gmail: use a 16-character App Password (not your normal account password)
SMTP_PASS=your-app-password-here
SMTP_FROM=you@gmail.com
